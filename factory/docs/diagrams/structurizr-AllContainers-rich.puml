@startuml
!pragma layout smetana
title <size:24>Container View: Internal Developer Platform</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <tupadr3/common>
!include <tupadr3/font-awesome-5/server>
!include <tupadr3/font-awesome-5/database>
!include <tupadr3/font-awesome-5/cloud>
!include <tupadr3/font-awesome-5/cogs>
!include <tupadr3/font-awesome-5/shield_alt>
!include <tupadr3/font-awesome-5/network_wired>
!include <tupadr3/font-awesome-5/satellite_dish>
!include <tupadr3/font-awesome-5/comments>
!include <tupadr3/font-awesome-5/sitemap>
!include <tupadr3/font-awesome-5/project_diagram>
!include <tupadr3/font-awesome-5/key>
!include <tupadr3/font-awesome-5/broadcast_tower>
!include <tupadr3/devicons/redis>
!include <tupadr3/devicons/postgresql>
!include <logos/kafka>
!include <logos/elasticsearch>
!include <logos/kubernetes>
!include <logos/auth0-icon>
!include <logos/azure>
!include <logos/graphql>

' ===== sync vs async edge styling =====
skinparam defaultTextAlignment center
' async edges carry «async» in label + technology event/stream; color them purple-dashed
AddRelTag("async", $textColor="#8e44ad", $lineColor="#8e44ad", $lineStyle=DashedLine())


Person(EndUser, "End User", $descr="Chats, opens GraphQL/UI, receives realtime streams.", $tags="", $link="")
System(IoTTelemetrySource, "IoT / Telemetry Source", $descr="Pushes sensor data to ingest.", $tags="", $link="", $sprite="satellite_dish")
System(ExternalWebhookReceiver, "External Webhook Receiver", $descr="3rd-party HTTPS endpoint.", $tags="", $link="", $sprite="cloud")
System(Auth0, "Auth0", $descr="Hosted identity provider (OIDC/JWT).", $tags="", $link="", $sprite="auth0-icon")
System(AzureAPIM, "Azure APIM", $descr="API gateway - dual auth (JWT OR sub-key).", $tags="", $link="", $sprite="azure")
System(AzureKeyVault, "Azure Key Vault", $descr="Secret store (Auth0 creds).", $tags="", $link="", $sprite="key")

AddBoundaryTag("idp_root", $borderColor="#1b2631", $fontColor="#1b2631", $borderStyle="bold")
System_Boundary("InternalDeveloperPlatform_boundary", "Internal Developer Platform\n[mesh: Istio mTLS + per-svc JWT]", $tags="idp_root") {
  AddBoundaryTag("Data stores (standalone CDs)", $borderColor="#2471a3", $fontColor="#2471a3", $borderStyle="bold")
  Boundary(group_1, "Data stores (standalone CDs)\n[DATA/SECRET] at-rest; in-mesh only", $tags="Data stores (standalone CDs)") {
    Container(InternalDeveloperPlatform.postgresql, "postgresql", $techn="Helm / Postgres", $descr="Relational DB (Crossplane Helm).", $tags="", $link="", $sprite="postgresql")
    Container(InternalDeveloperPlatform.neonpostgres, "neon-postgres", $techn="Neon API", $descr="Serverless Postgres (autoscale/branching).", $tags="", $link="", $sprite="postgresql")
    Container(InternalDeveloperPlatform.redis, "redis", $techn="Helm / Redis", $descr="Cache / queue.", $tags="", $link="", $sprite="redis")
    Container(InternalDeveloperPlatform.kafka, "kafka", $techn="Strimzi", $descr="Standalone event streaming.", $tags="", $link="", $sprite="kafka")
  }

  AddBoundaryTag("Edge", $borderColor="#e67e22", $fontColor="#e67e22", $borderStyle="bold")
  Boundary(group_2, "Edge\n[EDGE/DMZ] Istio mTLS terminate", $tags="Edge") {
    Container(InternalDeveloperPlatform.IstioIngressGateway, "Istio Ingress Gateway", $techn="Istio 1.27", $descr="Single LB entrypoint (*.nip.io); mTLS mesh.", $tags="", $link="", $sprite="network_wired")
  }

  AddBoundaryTag("Identity", $borderColor="#2471a3", $fontColor="#2471a3", $borderStyle="bold")
  Boundary(group_3, "Identity\n[DATA/SECRET] ESO->Key Vault", $tags="Identity") {
    Container(InternalDeveloperPlatform.auth0idp, "auth0-idp", $techn="ExternalSecret", $descr="ESO pulls Auth0 creds from Key Vault → <name>-conn for JWT verify.", $tags="", $link="", $sprite="auth0-icon")
  }

  AddBoundaryTag("Platform plane (shared)", $borderColor="#7f8c8d", $fontColor="#7f8c8d", $borderStyle="bold")
  Boundary(group_4, "Platform plane (shared)\n[INTERNAL] control plane RBAC", $tags="Platform plane (shared)") {
    Container(InternalDeveloperPlatform.KubeVela, "KubeVela", $techn="vela-core", $descr="Renders OAM → workloads + claims.", $tags="", $link="", $sprite="kubernetes")
    Container(InternalDeveloperPlatform.Crossplane, "Crossplane", $techn="v2.3", $descr="Reconciles backing-infra claims.", $tags="", $link="", $sprite="kubernetes")
    Container(InternalDeveloperPlatform.ArgoCD, "ArgoCD", $techn="v3.4", $descr="GitOps sync per-service repos.", $tags="", $link="", $sprite="kubernetes")
    Container(InternalDeveloperPlatform.KnativeServing, "Knative Serving", $techn="v1.22", $descr="Scale-to-zero runtime.", $tags="", $link="", $sprite="kubernetes")
  }

  AddBoundaryTag("camunda-orchestrator (app + bundled deps)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_5, "camunda-orchestrator (app + bundled deps)\n[INTERNAL] mesh mTLS", $tags="camunda-orchestrator (app + bundled deps)") {
    Container(InternalDeveloperPlatform.Zeebebroker, "Zeebe broker", $techn="Camunda 8 / Zeebe", $descr="BPMN workflow engine.", $tags="", $link="", $sprite="project_diagram")
    Container(InternalDeveloperPlatform.Operate, "Operate", $techn="Camunda 8", $descr="Process monitoring UI.", $tags="", $link="", $sprite="project_diagram")
    Container(InternalDeveloperPlatform.Tasklist, "Tasklist", $techn="Camunda 8", $descr="Human task UI.", $tags="", $link="", $sprite="project_diagram")
    Container(InternalDeveloperPlatform.Optimize, "Optimize", $techn="Camunda 8", $descr="Process analytics.", $tags="", $link="", $sprite="project_diagram")
    Container(InternalDeveloperPlatform.Elasticsearch, "Elasticsearch", $techn="Elasticsearch", $descr="Operate/Tasklist/Optimize datastore.", $tags="", $link="", $sprite="elasticsearch")
    Container(InternalDeveloperPlatform.zeebeworkerksvc, "zeebe-worker ksvc", $techn="Knative / FastAPI", $descr="Job workers (handlers.py).", $tags="", $link="", $sprite="project_diagram")
  }

  AddBoundaryTag("graphql (gateway + platform)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_6, "graphql (gateway + platform)\n[INTERNAL] Hive JWT-enforced", $tags="graphql (gateway + platform)") {
    Container(InternalDeveloperPlatform.HiveGateway, "Hive Gateway", $techn="Knative / Hive", $descr="Auto-federates sibling GraphQL subgraphs; JWT-enforced.", $tags="", $link="", $sprite="graphql")
    Container(InternalDeveloperPlatform.graphqlplatformRedis, "graphql-platform Redis", $techn="Helm / Redis", $descr="Gateway cache + config (ConfigMap).", $tags="", $link="", $sprite="redis")
    Container(InternalDeveloperPlatform.subgraphaksvc, "subgraph-a ksvc", $techn="Knative", $descr="Federated GraphQL subgraph.", $tags="", $link="", $sprite="graphql")
    Container(InternalDeveloperPlatform.subgraphbksvc, "subgraph-b ksvc", $techn="Knative", $descr="Federated GraphQL subgraph.", $tags="", $link="", $sprite="graphql")
  }

  AddBoundaryTag("identity-service (app)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_7, "identity-service (app)\n[INTERNAL] issues/validates JWT", $tags="identity-service (app)") {
    Container(InternalDeveloperPlatform.identityserviceksvc, "identity-service ksvc", $techn="Knative / Spring Boot", $descr="Domain IAM service; issues/validates tokens.", $tags="", $link="", $sprite="kubernetes")
  }

  AddBoundaryTag("rasa-chatbot (app)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_8, "rasa-chatbot (app)\n[INTERNAL] mesh mTLS", $tags="rasa-chatbot (app)") {
    Container(InternalDeveloperPlatform.Rasaserver, "Rasa server", $techn="Knative / Rasa", $descr="NLU + dialogue (prebaked model).", $tags="", $link="", $sprite="comments")
    Container(InternalDeveloperPlatform.Rasaactions, "Rasa actions", $techn="Knative / Rasa SDK", $descr="Custom action server.", $tags="", $link="", $sprite="comments")
  }

  AddBoundaryTag("realtime-platform (app + bundled deps)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_9, "realtime-platform (app + bundled deps)\n[INTERNAL] mesh mTLS", $tags="realtime-platform (app + bundled deps)") {
    Container(InternalDeveloperPlatform.Kafkabroker, "Kafka broker", $techn="Strimzi / Kafka", $descr="Topics: sensor_raw, sensor_agg, ...", $tags="", $link="", $sprite="kafka")
    Container(InternalDeveloperPlatform.LensesHQ, "Lenses HQ", $techn="Lenses CE 6.2", $descr="Stream-SQL console + management UI.", $tags="", $link="", $sprite="cogs")
    Container(InternalDeveloperPlatform.LensesAgent, "Lenses Agent", $techn="Lenses CE", $descr="Connects HQ to the Kafka cluster.", $tags="", $link="", $sprite="cogs")
    Container(InternalDeveloperPlatform.Metabase, "Metabase", $techn="Metabase", $descr="Analytics / dashboards over stream data.", $tags="", $link="", $sprite="project_diagram")
    Container(InternalDeveloperPlatform.MQTTbroker, "MQTT broker", $techn="Mosquitto", $descr="IoT ingest transport.", $tags="", $link="", $sprite="broadcast_tower")
    Container(InternalDeveloperPlatform.Postgresrtmeta, "Postgres (rt-meta)", $techn="Postgres", $descr="Lenses + Metabase metadata.", $tags="", $link="", $sprite="postgresql")
    Container(InternalDeveloperPlatform.realtimeserviceingest, "realtime-service: ingest", $techn="Knative / FastAPI", $descr="HTTP /ingest → produces sensor_raw.", $tags="", $link="", $sprite="satellite_dish")
    Container(InternalDeveloperPlatform.realtimeserviceprocessor, "realtime-service: processor", $techn="Knative / FastAPI", $descr="Consumes sensor_raw → aggregates → sensor_agg.", $tags="", $link="", $sprite="cogs")
    Container(InternalDeveloperPlatform.realtimeservicegateway, "realtime-service: gateway", $techn="Knative / FastAPI", $descr="Consumes sensor_agg → WebSocket /ws.", $tags="", $link="", $sprite="network_wired")
  }

  AddBoundaryTag("webhook-platform (app + bundled deps)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_10, "webhook-platform (app + bundled deps)\n[INTERNAL] HMAC-signed out; portal=EXTERNAL", $tags="webhook-platform (app + bundled deps)") {
    Container(InternalDeveloperPlatform.Svixengine, "Svix engine", $techn="svix-server v1.69", $descr="Outbound webhook delivery (HMAC sign, retry).", $tags="", $link="", $sprite="satellite_dish")
    Container(InternalDeveloperPlatform.Postgressvix, "Postgres (svix)", $techn="Postgres", $descr="Delivery metadata + logs.", $tags="", $link="", $sprite="postgresql")
    Container(InternalDeveloperPlatform.Redissvix, "Redis (svix)", $techn="Redis", $descr="Queue + retry backoff + cache.", $tags="", $link="", $sprite="redis")
    Container(InternalDeveloperPlatform.AppPortal, "App Portal", $techn="Istio VS", $descr="Externally-exposed self-service endpoint UI.", $tags="", $link="", $sprite="sitemap")
    Container(InternalDeveloperPlatform.realtimeservicewebhookbridge, "realtime-service: webhook bridge", $techn="Knative / FastAPI + realtime-transport", $descr="Consumes sensor_agg → POST Svix /msg.", $tags="", $link="", $sprite="satellite_dish")
  }

  AddBoundaryTag("webservice (app)", $borderColor="#27ae60", $fontColor="#27ae60", $borderStyle="bold")
  Boundary(group_11, "webservice (app)\n[INTERNAL] Auth0 JWT verify", $tags="webservice (app)") {
    Container(InternalDeveloperPlatform.webserviceksvc, "webservice ksvc", $techn="Knative / python|node|go|java", $descr="Onion-arch HTTP API; binds db/cache/identity; exposed via APIM.", $tags="", $link="", $sprite="kubernetes")
    Container(InternalDeveloperPlatform.webserviceshape, "webservice-shape", $techn="Knative", $descr="Shape-only ksvc primitive the webservice CD renders from.", $tags="", $link="", $sprite="server")
  }

}

Rel(InternalDeveloperPlatform.Tasklist, InternalDeveloperPlatform.Elasticsearch, "reads", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Optimize, InternalDeveloperPlatform.Elasticsearch, "reads", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Rasaserver, InternalDeveloperPlatform.Rasaactions, "custom actions", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.auth0idp, AzureKeyVault, "pulls Auth0 creds (ESO)", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.auth0idp, Auth0, "tenant", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.KubeVela, InternalDeveloperPlatform.Crossplane, "emits claims", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.KubeVela, InternalDeveloperPlatform.KnativeServing, "renders ksvc", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.ArgoCD, InternalDeveloperPlatform.KnativeServing, "syncs workloads", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Crossplane, InternalDeveloperPlatform.postgresql, "provisions", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Crossplane, InternalDeveloperPlatform.Kafkabroker, "provisions", $techn="", $tags="", $link="")
Rel(EndUser, InternalDeveloperPlatform.IstioIngressGateway, "HTTP / WS / chat", $techn="", $tags="", $link="")
Rel(IoTTelemetrySource, InternalDeveloperPlatform.MQTTbroker, "Telemetry (MQTT) «async»", $techn="event/stream", $tags="async", $link="")

Rel(IoTTelemetrySource, InternalDeveloperPlatform.realtimeserviceingest, "Telemetry (HTTP /ingest)", $techn="", $tags="", $link="")
Rel(AzureAPIM, InternalDeveloperPlatform.webserviceksvc, "expose-api route", $techn="", $tags="", $link="")
Rel(AzureAPIM, InternalDeveloperPlatform.HiveGateway, "federated GraphQL", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.realtimeserviceingest, "/ingest", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.realtimeservicegateway, "/ws", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.Operate, "Operate UI", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.Tasklist, "Tasklist UI", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.Rasaserver, "chat", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.identityserviceksvc, "token endpoints", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.IstioIngressGateway, InternalDeveloperPlatform.AppPortal, "self-service portal", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, InternalDeveloperPlatform.postgresql, "binds db", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, InternalDeveloperPlatform.redis, "binds cache", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, InternalDeveloperPlatform.neonpostgres, "binds (serverless pg alt)", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, InternalDeveloperPlatform.auth0idp, "binds identity", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, InternalDeveloperPlatform.webserviceshape, "rendered from", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.webserviceksvc, Auth0, "validates JWT", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.identityserviceksvc, InternalDeveloperPlatform.postgresql, "user store", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.realtimeserviceingest, InternalDeveloperPlatform.Kafkabroker, "produce sensor_raw «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Kafkabroker, InternalDeveloperPlatform.realtimeserviceprocessor, "consume sensor_raw «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.realtimeserviceprocessor, InternalDeveloperPlatform.Kafkabroker, "produce sensor_agg «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Kafkabroker, InternalDeveloperPlatform.realtimeservicegateway, "consume sensor_agg «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.realtimeservicegateway, EndUser, "WebSocket stream «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.LensesAgent, InternalDeveloperPlatform.Kafkabroker, "manages", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.LensesHQ, InternalDeveloperPlatform.LensesAgent, "controls", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Metabase, InternalDeveloperPlatform.Postgresrtmeta, "queries", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.LensesHQ, InternalDeveloperPlatform.Postgresrtmeta, "metadata", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.MQTTbroker, InternalDeveloperPlatform.Kafkabroker, "bridges to topics «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Kafkabroker, InternalDeveloperPlatform.realtimeservicewebhookbridge, "consume sensor_agg «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.realtimeservicewebhookbridge, InternalDeveloperPlatform.Svixengine, "POST /app/.../msg", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Svixengine, InternalDeveloperPlatform.Postgressvix, "store messages", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Svixengine, InternalDeveloperPlatform.Redissvix, "queue + retry «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Svixengine, InternalDeveloperPlatform.AppPortal, "serves", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.Svixengine, ExternalWebhookReceiver, "HMAC-signed delivery «async»", $techn="event/stream", $tags="async", $link="")

Rel(ExternalWebhookReceiver, InternalDeveloperPlatform.AppPortal, "self-registers endpoint", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.HiveGateway, InternalDeveloperPlatform.subgraphaksvc, "federates", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.HiveGateway, InternalDeveloperPlatform.subgraphbksvc, "federates", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.HiveGateway, InternalDeveloperPlatform.graphqlplatformRedis, "cache/config", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.HiveGateway, InternalDeveloperPlatform.webserviceksvc, "can federate webservice subgraph", $techn="", $tags="", $link="")
Rel(InternalDeveloperPlatform.zeebeworkerksvc, InternalDeveloperPlatform.Zeebebroker, "activates jobs «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Zeebebroker, InternalDeveloperPlatform.Elasticsearch, "exports records «async»", $techn="event/stream", $tags="async", $link="")

Rel(InternalDeveloperPlatform.Operate, InternalDeveloperPlatform.Elasticsearch, "reads", $techn="", $tags="", $link="")

hide stereotypes
caption <b>Trust zones:</b> <color:#e67e22><b>EDGE/DMZ</b></color> (Istio mTLS terminate)  |  <color:#27ae60><b>INTERNAL/mesh</b></color> (mTLS + JWT)  |  <color:#2471a3><b>DATA/secrets</b></color> (pg/redis/kafka/KV, at-rest)  |  <color:#c0392b><b>EXTERNAL/untrusted</b></color> (Auth0/APIM/IoT/webhook)        <b>Edges:</b> <color:#707070>solid</color> = sync (HTTP/REST/WS)  ,  <color:#8e44ad>dashed</color> = async (Kafka/queue/webhook)
@enduml